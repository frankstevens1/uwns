{
  "name": "df-bp-t01",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean-repo": "node ./tooling/clean-repo.js",
    "clean-repo:full": "node ./tooling/clean-repo.js --all",
    "api:reset": "node ./tooling/clean-repo.js --service api",
    "api:dev": "uv --cache-dir .uv-cache run --directory services/api uvicorn --env-file .env app.main:app --reload --host 0.0.0.0 --port 8000",
    "api:test": "uv --cache-dir .uv-cache run --directory services/api pytest",
    "ui:gen": "pnpm --filter @repo/ui gen",
    "ui:validate": "pnpm --filter @repo/ui validate",
    "ui:typecheck": "pnpm --filter @repo/ui typecheck",
    "gen:form": "tsx packages/forms/scripts/gen-form.ts",
    "notifications:generate": "node tooling/generate-notification-destinations.js",
    "notifications:verify": "node tooling/generate-notification-destinations.js --check",
    "notifications:test": "node --test tooling/generate-notification-destinations.test.js"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.10",
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "engines": {
    "node": ">=18"
  }
}
