# Shared Supabase config for web + native apps
# Web (Next.js)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55421
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Native (Expo)
# For Expo Go on a physical device, replace 127.0.0.1 with your computer's
# LAN IP and make sure the target service is bound to 0.0.0.0.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:55421
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Public URL used by web/native to call the FastAPI activity service.
# Service-only secrets live in services/api/.env.example.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Public web origin used by native to open docs in the system browser.
EXPO_PUBLIC_WEB_URL=http://127.0.0.1:3000

# shell 
NEXT_PUBLIC_MAILTO=hello@datafluent.one
NEXT_PUBLIC_GITHUB_USERNAME=frankstevens1
NEXT_PUBLIC_PRIVACY_URL=/legal#privacy
NEXT_PUBLIC_TERMS_URL=/legal#terms
