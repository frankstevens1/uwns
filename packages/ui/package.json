{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "default": "./src/index.web.ts"
    }
  },
  "scripts": {
